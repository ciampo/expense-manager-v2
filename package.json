{
  "name": "expense-manager-v2",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24.13.0",
    "pnpm": ">=10.28.2"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:e2e": "vite dev --port 3000 --mode e2e",
    "build": "vite build && pnpm typecheck",
    "preview": "vite preview",
    "preview:e2e": "vite build --mode e2e && vite preview --port 3000",
    "deploy": "pnpm build && wrangler deploy",
    "migrate": "convex run seed:postDeploy",
    "codegen": "npx convex codegen",
    "test": "pnpm test:unit",
    "test:watch": "pnpm test:unit:watch",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:unit:frontend": "vitest run --config vitest.config.ts src/",
    "test:unit:convex": "vitest run --config vitest.config.ts convex/",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:unit:coverage:changed": "vitest run --config vitest.config.ts --coverage --coverage.changed",
    "test:unit:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:seed": "convex run seed:e2e --prod",
    "test:e2e:cleanup": "convex run seed:cleanup --prod",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:visual:update": "playwright test --config playwright.visual.config.ts --update-snapshots",
    "test:visual:docker": "docker compose -f docker-compose.test.yml run --rm visual-tests pnpm run test:visual",
    "test:visual:docker:update": "docker compose -f docker-compose.test.yml run --rm visual-tests pnpm run test:visual:update",
    "test:visual:docker:full": "bash scripts/test-visual-local.sh",
    "test:visual:docker:full:update": "bash scripts/test-visual-local.sh --update-snapshots",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test:unit",
    "check:env": "bash scripts/check-env.sh",
    "setup": "bash scripts/setup.sh",
    "setup:e2e": "bash scripts/setup-e2e.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/core": "0.37.0",
    "@base-ui/react": "^1.3.0",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.1.0",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@marsidev/react-turnstile": "^1.5.0",
    "@oslojs/crypto": "^1.0.1",
    "@tanstack/react-form": "^1.28.5",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.8",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.13",
    "@tanstack/router-plugin": "^1.167.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.34.0",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/vite-plugin": "^1.30.0",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-query-devtools": "^5.95.2",
    "@tanstack/react-router-devtools": "^1.166.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.1",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "convex-test": "^0.0.43",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.76.0"
  },
  "pnpm": {
    "overrides": {
      "h3-v2": "npm:h3@2.0.1-rc.18",
      "flatted": "^3.4.2"
    }
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  }
}
