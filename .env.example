# === Local Development ===

# Convex development deployment URL
# Get from: Convex Dashboard → your project → Settings → URL
# This is auto-populated when you run `npx convex dev`
VITE_CONVEX_URL=https://your-project.convex.cloud

# Convex deployment identifier (auto-populated by `npx convex dev`)
CONVEX_DEPLOYMENT=dev:your-project # team: your-team, project: your-project

# === Cloudflare Turnstile (optional) ===

# Site key for Cloudflare Turnstile bot protection on auth forms.
# Get from: Cloudflare Dashboard → Turnstile → Add Widget → copy Site Key.
# When unset, the Turnstile widget is not rendered and server-side
# validation is skipped. This keeps local development frictionless.
# VITE_TURNSTILE_SITE_KEY=0x...

# === Production Deployment (optional, for manual deploys) ===

# Production deploy key for Convex backend deployment
# Get from: Convex Dashboard → your project → Settings → Deploy Keys
# CONVEX_DEPLOY_KEY=prod:your-project-deploy-key

# === Registration Controls (Convex env vars, not local) ===
# These are set via `npx convex env set`, not in this file.
# Shown here for reference — see docs/ENVIRONMENT_VARIABLES.md for details.
#
# Comma-separated list of allowed emails or domain wildcards.
# Empty/unset = allow all emails (no filtering).
# ALLOWED_EMAILS=your-email@example.com,*@mycompany.org
#
# Set to "false" to instantly block all new sign-ups.
# Any other value or unset = registration open (subject to allowlist).
# REGISTRATION_ENABLED=false
